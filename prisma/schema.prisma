generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id            String   @id @default(cuid())
  firstName     String
  email         String   @unique
  lastEmailDay  Int      @default(0) // Tracks the last email day sent (0, 2, 4, 6...)
  isActive      Boolean  @default(true) // Set to false if they unsubscribe
  createdAt     DateTime @default(now())
}
